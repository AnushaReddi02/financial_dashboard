<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="container">

    <h2 class="page-title">Transactions</h2>

    <!-- ADMIN BUTTON -->
    <button class="add-btn">+ Add Transaction</button>
    <div id="formContainer" class="form-container" style="display:none;">
    <input type="text" id="newCategory" placeholder="Category">
    <input type="number" id="newAmount" placeholder="Amount">
    <select id="newType">
        <option value="income">Income</option>
        <option value="expense">Expense</option>
    </select>
    <button onclick="addTransaction()">Add</button>
</div>

    <input type="text" id="search" placeholder="Search category..." />

    <!-- TABLE WRAPPER FOR RESPONSIVENESS -->
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Category</th>
                    <th>Type</th>
                </tr>
            </thead>

            <tbody id="tableBody">
                <% transactions.forEach(t => { %>
                    <tr>
                        <td><%= t.date %></td>
                        <td>₹<%= t.amount %></td>
                        <td class="category"><%= t.category %></td>
                        <td><%= t.type %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

</div>

<%- include("partials/footer") %>