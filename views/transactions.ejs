<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="container">

    <h2 class="page-title">Transactions</h2>

    <!-- ADMIN BUTTON -->
    <a href="/add">
        <button class="add-btn">+ Add Transaction</button>
    </a>

    <input type="text" id="search" placeholder="Search category..." />

    <!-- TABLE WRAPPER -->
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Category</th>
                    <th>Type</th>
                    <th>Action</th>
                </tr>
            </thead>

            <!-- ⚠️ IMPORTANT: EMPTY tbody -->
            <tbody id="tableBody">
    <% transactions.forEach((t, index) => { %>
        <tr>
            <td><%= t.date %></td>
            <td>₹<%= t.amount %></td>
            <td class="category"><%= t.category %></td>
            <td><%= t.type %></td>
            <td>
                <button class="delete-btn" onclick="deleteTransaction(<%= index %>)">
                    Delete
                </button>
            </td>
        </tr>
    <% }) %>
</tbody>
        </table>
    </div>

</div>

<%- include("partials/footer") %>