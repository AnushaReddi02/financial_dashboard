<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="container">

    <h2 class="page-title">📊 Insights</h2>

    <% 
        const expenses = transactions.filter(t => t.type === "expense");
        const totalExpense = expenses.reduce((sum, t) => sum + t.amount, 0);
        const highest = expenses.sort((a,b) => b.amount - a.amount)[0];
        const percentage = ((highest.amount / totalExpense) * 100).toFixed(1);
    %>

    <div class="insight-card">
        <h3>💸 Highest Spending Category</h3>

        <p class="highlight"><%= highest.category %></p>

        <p class="sub-text">
            You spent ₹<%= highest.amount %> on this category.
        </p>

        <p class="sub-text">
            This accounts for <strong><%= percentage %>%</strong> of your total expenses.
        </p>
    </div>

</div>

<%- include("partials/footer") %>